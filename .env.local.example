# ata100 薪酬域会员中心 —— env 模板。复制成 .env.local 填真值（.env.local 不进 git）。
# session 密钥生成：node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"

# ── 共享会员 cookie 密钥（A500/ata-doc-library 必须填同一个值，否则跨产品登录态解不开）──
ATA_MEMBER_SESSION_PASSWORD=<generate-with-the-command-above>
ATA_COOKIE_SECURE=false
ATA100_API_PORT=4004

# 本地短信旁路（上线必须删）：用此码可绕过真实验证码登录
MASTER_OTP_CODE=888888

# 个人历史聚合：各业务积木库路径（只读挂载）
ATA_SALARY_DB_PATH=../A500-薪资查询-salary-report/data/salary-report.db
ATA_DOC_DB_PATH=../ata-doc-library/data/doc-library.db

# ── Phase 5-6 真短信/真支付凭证（留空自动走 fake/DEV 模式）──
# SMSBAO_USER=
# SMSBAO_PASS=
# SMSBAO_SIGN=【谨世智能】   # 与 A200 同值；值必须自带【】方括号，留空则用代码内默认「【谨世智能】」
# WECHAT_OFFICIAL_ACCOUNT_APPID=
# WECHAT_OFFICIAL_ACCOUNT_SECRET=
# WECHAT_PAY_MCH_ID=1683774591
# WECHAT_PAY_SERIAL_NO=
# WECHAT_PAY_PRIVATE_KEY_B64=
# WECHAT_PAY_API_V3_KEY=
# WECHAT_PAY_PUBLIC_KEY_B64=
# WECHAT_PAY_PUBLIC_KEY_ID=
# ATA_WECHAT_NOTIFY_URL=
# ATA_OAUTH_REDIRECT_URI=

# ── 部署到子路径时打开 ──
# VITE_BASE_PATH=/ata100/
# ATA_COOKIE_PATH=/
