# ════════════════════════════════════════════════════════════
# ata100 薪酬域会员中心 —— 生产 env 模板
# 部署时复制成 .env.local（或 .env.production.local），填真值。
# 真值来源：D:\_workspace\.secrets\wechatpay\1683774591\env-values.env + A200 的 .env.local
# 部署网址：https://h100.jsai100.com/ata100/   端口：4004
# ════════════════════════════════════════════════════════════

NODE_ENV=production
ATA100_API_PORT=4004

# ── 子路径部署（关键）──
VITE_BASE_PATH=/ata100/
# cookie 设全站 path，让 A500(/a500/) 和文档库(/ata-docs/) 能读到同一张会员卡。
# session 只装 {phone,userId} 几十字节，全站广播代价可忽略。
ATA_COOKIE_PATH=/
ATA_COOKIE_SECURE=true

# ── 共享会员 cookie 密钥（A500/ata-doc-library 必须填同一个值）──
# 生成：node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
ATA_MEMBER_SESSION_PASSWORD=<生成一个48字节随机串，三产品共用同一个>

# ── 短信宝（复用 A200 账户，值从 A200 .env.local 取）──
SMSBAO_USER=<同A200>
SMSBAO_PASS=<同A200>
SMSBAO_SIGN=<同A200报备的签名，必须一致否则发送失败>
# 上线后删掉 MASTER_OTP_CODE（保留=任何人用此码可登录，安全漏洞）

# ── 微信支付（复用商户 1683774591，值从 .secrets/wechatpay/1683774591/env-values.env 取）──
WECHAT_OFFICIAL_ACCOUNT_APPID=<谨世智云服务号 AppID，同A200>
WECHAT_OFFICIAL_ACCOUNT_SECRET=<同A200>
WECHAT_PAY_MCH_ID=1683774591
WECHAT_PAY_SERIAL_NO=6BE958C1866B3127D6938572E0C4C690B856D1F0
WECHAT_PAY_API_V3_KEY=<同A200/secrets>
WECHAT_PAY_PRIVATE_KEY_B64=<apiclient_key.pem 转 base64>
WECHAT_PAY_PUBLIC_KEY_B64=<pub_key.pem 转 base64>
WECHAT_PAY_PUBLIC_KEY_ID=PUB_KEY_ID_0116837745912024112800297900000550

# ── ata100 专属 URL（必须是新地址，asg100 的不通用）──
# notify_url 必须公网 https 可达。商户后台 h100.jsai100.com 已授权（覆盖所有子路径）。
ATA_WECHAT_NOTIFY_URL=https://h100.jsai100.com/ata100/api/pay/wechat/notify
ATA_OAUTH_REDIRECT_URI=https://h100.jsai100.com/ata100/api/wechat/oauth/callback

# 跨产品回跳白名单域名
ATA_ALLOWED_HOST=h100.jsai100.com

# ── 个人历史聚合：各业务积木库的服务器绝对路径 ──
ATA_SALARY_DB_PATH=/var/www/salary-report/data/salary-report.db
# ata-doc-library 暂未部署，留空走降级（空历史）
# ATA_DOC_DB_PATH=/var/www/ata-doc-library/data/doc-library.db
